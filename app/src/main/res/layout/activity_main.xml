<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hello World!"
        android:layout_weight="1" />
    <com.gemminiii.library.TextView.DefaultTextView.DefaultTextView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        app:sCornerRadius="5dp"
        app:sCommonCornerRadiusFlag="true"
        app:sCommonColor="@android:color/holo_red_dark"
        app:sStrokeWidth="2dp"
        app:sMarginAllButton="3dp"
        app:sLeftIcon="@drawable/ic_update_vector"
        app:sRightIcon="@drawable/ic_update_vector"/>
    <com.gemminiii.library.Button.DefaultKvantMaterialButton.DefaultMaterialButton
        android:id="@+id/test_btn"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Тест библиотеки" />
</LinearLayout>