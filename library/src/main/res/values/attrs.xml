<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="DefaultMaterialButton">
        <attr name="buttonCornerRadius" format="dimension" />
        <attr name="buttonBackgroundColor" format="color|reference" />
        <attr name="buttonGradientStart" format="color" />
        <attr name="buttonGradientEnd" format="color" />
        <attr name="buttonStrokeWidth" format="dimension" />
        <attr name="buttonStrokeColor" format="color" />
        <attr name="buttonPadding" format="dimension" />

        <attr name="buttonIcon" format="reference" />
        <attr name="buttonIconSize" format="dimension"/>
        <attr name="buttonIconTint" format="color|reference"/>
        <attr name="buttonIconGravity" format="enum">
            <enum name="start" value="0" />
            <enum name="end" value="1" />
            <enum name="center" value="2" />
        </attr>

        <attr name="buttonIconPadding" format="dimension" />
        <attr name="buttonTextColor" format="color|reference" />
        <attr name="buttonTextSize" format="dimension" />
        <attr name="buttonTypeface" format="string" />
    </declare-styleable>
</resources>