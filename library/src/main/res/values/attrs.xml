<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <attr name="sCornerRadius" format="dimension" />
    <attr name="sBackgroundColor" format="color|reference" />
    <attr name="sGradientStart" format="color"/>
    <attr name="sGradientEnd" format="color" />
    <attr name="sStrokeWidth" format="dimension" />
    <attr name="sStrokeColor" format="color" />
    <attr name="sIcon" format="reference" />
    <attr name="sIconSize" format="dimension"/>
    <attr name="sIconTint" format="color|reference"/>
    <attr name="sIconGravity" format="enum">
        <enum name="start" value="0" />
        <enum name="end" value="1" />
        <enum name="center" value="2" />
    </attr>

    <attr name="sIconPadding" format="dimension" />
    <attr name="sTextColor" format="color|reference" />
    <attr name="sTextSize" format="dimension" />
    <attr name="sTypeface" format="string" />
    <attr name="sCommonColor" format="color|reference" />
    <attr name="sCommonPadding" format="dimension" />
    <attr name="sCommonMargin" format="dimension" />

    <declare-styleable name="DefaultListParam">
        <attr name="sIcon"/>
        <attr name="sIconSize"/>
        <attr name="sIconTint" />
        <attr name="sIconGravity"/>
        <attr name="sIconPadding"/>
        <attr name="sTextColor" />
        <attr name="sTextSize"/>
        <attr name="sTypeface"/>
        <attr name="sCommonColor"/>
        <attr name="sCommonPadding"/>
        <attr name="sCommonMargin"/>
    </declare-styleable>

    <declare-styleable name="DefaultTextView">
        <attr name="sCommonColorFlag" format="boolean" />
        <attr name="sCommonCornerRadiusFlag" format="boolean" />
<!--        text element-->
        <attr name="sCornerRadiusTextElem" format="dimension" />
        <attr name="sBackgroundColorTextElem" format="color|reference" />
        <attr name="sStrokeWidthTextElem" format="dimension" />
        <attr name="sStrokeColorTextElem" format="color" />
        <attr name="sPaddingTextElem" format="dimension" />
        <attr name="sTextElem" format="string" />
        <attr name="sTextColorElem" format="color|reference" />
        <attr name="sTextSizeElem" format="dimension" />
        <attr name="sTypefaceElem" format="string" />

        <attr name="sButtonsVisibility" format="enum">
            <enum name="none" value="0" />
            <enum name="left" value="1"/>
            <enum name="right" value="2"/>
            <enum name="all" value="3"/>
        </attr>
        <attr name="sBottomStatusVisibility" format="enum">
            <enum name="none" value="0"/>
            <enum name="text" value="1"/>
            <enum name="progress" value="2"/>
        </attr>
        <attr name="sHeaderPositionMode" format="enum">
            <enum name = "NONE" value="0"/>
            <enum name = "TOP" value="1"/>
            <enum name = "LEFT" value="2"/>
            <enum name = "RIGHT" value="3"/>
        </attr>

<!--        Left/Right Button element-->
        <attr name="sCornerRadiusAllButton" format="dimension" />
        <attr name="sBackgroundColorAllButton" format="color|reference" />
        <attr name="sStrokeWidthAllButton" format="dimension" />
        <attr name="sStrokeColorAllButton" format="color" />
        <attr name="sPaddingAllButton" format="dimension" />
        <attr name="sMarginAllButton" format="dimension" />
        <attr name="sLeftIcon" format="reference" />
        <attr name="sRightIcon" format="reference"/>

        <!--        Bottom element-->
        <attr name="sCornerRadiusBottomElem" format="dimension" />
        <attr name="sBackgroundColorBottomElem" format="color|reference" />
        <attr name="sStrokeWidthBottomElem" format="dimension" />
        <attr name="sStrokeColorBottomElem" format="color" />
        <attr name="sPaddingBottomElem" format="dimension" />
        <attr name="sTextBottomElem" format="string" />
        <attr name="sTextColorBottomElem" format="color|reference" />
        <attr name="sTextSizeBottomElem" format="dimension" />
        <attr name="sTypefaceBottomElem" format="string" />
        <attr name="sBottomProgressBackgroundColor" format="color|reference" />
        <attr name="sBottomProgressTrackColor" format="color|reference" />

        <attr name="sCornerRadiusHeader" format="dimension" />
        <attr name="sBackgroundColorHeader" format="color|reference" />
        <attr name="sStrokeWidthHeader" format="dimension" />
        <attr name="sStrokeColorHeader" format="color" />
        <attr name="sPaddingHeader" format="dimension" />
        <attr name="sTextBotHeader" format="string" />
        <attr name="sTextColorHeader" format="color|reference" />
        <attr name="sTextSizeHeader" format="dimension" />
        <attr name="sTypefaceHeader" format="string" />

        <attr name="sCornerRadius"/>
        <attr name="sBackgroundColor"/>
        <attr name="sGradientStart"/>
        <attr name="sGradientEnd"/>
        <attr name="sStrokeWidth"/>
        <attr name="sStrokeColor"/>
        <attr name="sCommonPadding"/>
        <attr name="sCommonMargin"/>

        <attr name="sIcon"/>
        <attr name="sIconSize"/>
        <attr name="sIconTint"/>
        <attr name="sIconGravity"/>

        <attr name="sIconPadding"/>
        <attr name="sTextColor"/>
        <attr name="sTextSize" />
        <attr name="sTypeface"/>
        <attr name="sCommonColor" />


    </declare-styleable>
</resources>